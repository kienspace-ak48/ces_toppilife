<header class="header header-sticky p-0 mb-4">
  <div class="container-fluid border-bottom px-4">
    <button
      class="header-toggler"
      type="button"
      onclick="coreui.Sidebar.getInstance(document.querySelector('#sidebar')).toggle()"
      style="margin-inline-start: -14px;"
    >
      <svg class="icon icon-lg">
        <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-menu"></use>
      </svg>
    </button>

    <ul class="header-nav d-none d-lg-flex">
      <li class="nav-item">
        <a class="nav-link" href="/admin">Dashboard</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/admin/page-config">Page config</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/admin/gallery">Gallery</a>
      </li>
    </ul>

    <ul class="header-nav ms-auto">
      <li class="nav-item dropdown">
        <a
          class="nav-link py-0 pe-0 d-flex align-items-center"
          data-coreui-toggle="dropdown"
          href="#"
          role="button"
          aria-haspopup="true"
          aria-expanded="false"
        >
          <div class="avatar avatar-md bg-primary text-white fw-bold d-flex align-items-center justify-content-center">
            <%= (typeof user !== 'undefined' && user?.name ? user.name.charAt(0).toUpperCase() : 'A') %>
          </div>
          <div class="d-none d-md-block ms-2 text-start">
            <div class="fw-semibold"><%= (typeof user !== 'undefined' && user?.name) || 'Admin' %></div>
            <div class="small text-body-secondary"><%= (typeof user !== 'undefined' && user?.role) || 'Super Admin' %></div>
          </div>
        </a>
        <div class="dropdown-menu dropdown-menu-end pt-0">
          <div class="dropdown-header bg-body-tertiary text-body-secondary fw-semibold rounded-top mb-2">
            Account
          </div>
          <form action="/auth/admin/logout" method="post">
            <button class="dropdown-item" type="submit">
              <svg class="icon me-2">
                <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-account-logout"></use>
              </svg>
              Logout
            </button>
          </form>
        </div>
      </li>
    </ul>
  </div>
</header>
