<template id="solution_template">
  <div class="instance relative">
    <span type="button" class="remove-item flex justify-center items-center rounded-full h-5 w-5 bg-red-500 absolute -top-2 right-2 font-bold text-white hover:scale-120 hover:cursor-pointer">X</span>
    <input
          name="icon"
          placeholder="Icon"
          class="border w-full px-3 py-2 rounded"
        />

        <input
          name="title"
          placeholder="Title"
          class="border w-full px-3 py-2 rounded"
        />

        <textarea
          name="desc"
          placeholder="Desc"
          class="border w-full px-3 py-2 rounded"
        ></textarea>
  </div>
</template>
<!-- ------------------- BENEFITS ---------------->
<template id="benefit_template">
  <div class="instance relative">
    <span class="h-5 w-5 remove-instance  border rounded-full flex justify-center items-center border-gray-300 bg-red-500 font-bold text-white hover:cursor-pointer hover:scale-120 absolute -top-2 right-2">X</span>
    <div>
      <!-- <input type="text" name="img_url" id="" class="px-3 py-2 border border-gray-300 rounded-lg w-full" placeholder="imgage"> -->
       <!-- image handle action -->
    <div class="image_action">
      <!-- <label for="">Image banner</label> -->
      <div class="flex justify-between items-center mt-3">
        <button
        type="button"
          class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
        >
          Chọn ảnh
        </button>
        <input
          type="text"
          name="img_url"
          value="<%#=pc?.issue?.card?.img_url||''%>"
          class="flex-3 img_input w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
          placeholder="img"
        />
      </div>
      <div class="img_preview border border-gray-300 w-full h-[200px]">
        <img
          src="#/<%=pc?.issue?.card?.img_url||''%>"
          alt=""
          class="w-full object-cover max-h-[200px]"
        />
      </div>
    </div>
        <!--  -->
      <input type="text" name="icon" id="" class="px-3 py-2 border border-gray-300 rounded-lg w-full " placeholder="icon">
      <input type="text" name="title" id="" class="px-3 py-2 border border-gray-300 rounded-lg w-full " placeholder="title">
      <input type="text" name="desc" id="" class="px-3 py-2 border border-gray-300 rounded-lg w-full " placeholder="desc">
    </div>

  </div>
</template>
