                        class="w-full object-cover max-h-[200px]"
                      />
                    </div>
                  </div>
                      <!--  -->

        <textarea
          id="target_user_list"
          placeholder="enter = 1 sentence"
          class="border w-full px-3 py-2 rounded"
        ><%=pc?.target_user?.list.join('\n')%></textarea>
