          <input value="<%=pc?.benefit?.footer_card.lable%>" id="benefit_footer_title" type="text" class="form-control" placeholder="desc">
          <textarea name="" class="form-control" id="benefit_footer_solution" placeholder="1 Enter = 1 sentence"><%=pc?.benefit?.footer_card.solution.join('\n')%></textarea>
        </div>
