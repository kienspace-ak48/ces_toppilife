        Target Section
        <span>+</span>
      </button>
      <!-- Content -->
      <div class="p-4" id="target_user">
        <input
          name="target_user_title"
          value="<%=pc?.target_user?.title||''%>"
          placeholder="Title"
          class="border w-full px-3 py-2 rounded"
        />

        <!-- <input
          name="target_user_img_url"
          value="<%#=pc?.target_user?.img_url||''%>"
          placeholder="Image URL"
          class="border w-full px-3 py-2 rounded"
        /> -->
        <!--  -->
        <!-- image handle action -->
                  <h5 class="font-bold">Image <small>(750x500)</small></h5>
                  <div class="image_action">
                    <!-- <label for="">Image banner</label> -->
                    <div class="flex justify-between items-center mt-3">
                      <button
                      type="button"
                        class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
