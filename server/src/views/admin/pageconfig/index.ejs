                      name="desc"
                      placeholder="Desc"
                      class="border w-full px-3 py-2 rounded"
                    ><%=c.desc%></textarea>
              </div>
            <%})%>
          <%}%>
        </div>

        
      </div>
    </section>
    <!-- BENEFITS -->
    <section class="border rounded-lg">
