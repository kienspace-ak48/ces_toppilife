                        Chọn ảnh
                      </button>
                      <input
                        type="text"
                        name="img_url"
                        value="<%=b.img_url%>"
                        class="flex-3 img_input w-full px-4 py-3 border border-gray-300 rounded-lg hidden"
                        placeholder="img"
                      />
                    </div>
                    <div class="img_preview border border-gray-300 w-full h-[200px]">
                      <img
                        src="/<%=b.img_url%>"
                        alt=""
                        class="w-full object-cover max-h-[200px]"
                      />
                    </div>
                  </div>
                      <!--  -->
                  <input value="<%=b.icon%>" type="text" name="icon" id="" class="px-3 py-2 border border-gray-300 rounded-lg w-full " placeholder="icon">
                  <input value="<%=b.title%>" type="text" name="title" id="" class="px-3 py-2 border border-gray-300 rounded-lg w-full " placeholder="title">
                  <input value="<%=b.desc%>" type="text" name="desc" id="" class="px-3 py-2 border border-gray-300 rounded-lg w-full " placeholder="desc">
                </div>
              </div>
            <%})%>
          <%}%>
        </div>
        <!--  -->
        <h3 class="font-bold">Footer card</h3>
        <div>
          <!-- <input value="<%#=pc?.benefit?.footer_card.img_url%>" id="benefit_footer_img_url" type="text" class="px-3 py-2 border border-gray-300 rounded-lg w-full" placeholder="img_url"> -->
          <!-- image handle action -->
                  <div class="image_action">
                    <!-- <label for="">Image banner</label> -->
                    <div class="flex justify-between items-center mt-3">
                      <button
                      type="button"
                        class="flex-1 px-4 py-3 chooseImg rounded-lg border border-green-500"
                      >
                        Chọn ảnh
                      </button>
                      <input
                        type="text"
                        id="benefit_footer_img_url"
