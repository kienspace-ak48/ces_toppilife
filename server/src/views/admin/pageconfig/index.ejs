              <div class="instance position-relative admin-sub-card">
                <span type="button" class="remove-instance d-flex justify-content-center align-items-center rounded-circle admin-remove-size bg-danger position-absolute admin-top-n2 admin-right-2 fw-bold text-white">X</span>
