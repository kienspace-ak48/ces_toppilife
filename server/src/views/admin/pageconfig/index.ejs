        </div>
        <div id="testimonial_wrapper" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <%if(pc?.testimonials && pc?.testimonials.length>0){%>
            <%pc?.testimonials.forEach(i=>{%>
