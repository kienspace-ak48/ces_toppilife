                        placeholder="img"
                      />
                    </div>
                    <div class="img_preview border border-gray-300 w-full h-[200px]">
                      <img
                        src="/<%=pc?.benefit?.footer_card.img_url%>"
                        alt=""
                        class="w-full object-cover max-h-[200px]"
                      />
                    </div>
                  </div>
                      <!--  -->
          <input value="<%=pc?.benefit?.footer_card.lable%>" id="benefit_footer_title" type="text" class="px-3 py-2 border border-gray-300 rounded-lg w-full" placeholder="desc">
          <textarea name="" class="px-3 py-2 border border-gray-300 rounded-lg w-full" id="benefit_footer_solution" placeholder="1 Enter = 1 sentence"><%=pc?.benefit?.footer_card.solution.join('\n')%></textarea>
        </div>
      </div>
    </section>
    <!-- END -->

    <!-- END -->
    <!-- TARGET_USER -->
    <section class="border rounded-lg">
      <button
        type="button"
        onclick="toggleSection('target_user')"
        class="w-full flex justify-between p-4 font-medium"
