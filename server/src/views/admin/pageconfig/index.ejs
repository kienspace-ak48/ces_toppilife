      <button
        type="button"
        onclick="toggleSection('safety_notice')"
        class="admin-section-toggle btn btn-link w-100 d-flex justify-content-between align-items-center text-start text-decoration-none fw-semibold"
      >
        Safety Notice — Lưu ý và chống chỉ định
        <span>+</span>
      </button>
      <div class="card-body" id="safety_notice">
        <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-3">
          <div>
            <h4 class="fw-bold mb-1">Lưu ý và chống chỉ định</h4>
            <p class="text-body-secondary small mb-0">
              Hiển thị trước FAQ. Mỗi box gồm tiêu đề và nội dung rich text.
            </p>
          </div>
          <button id="cta_add_safety_box" type="button" class="btn btn-success fw-semibold">
            Thêm box nội dung
          </button>
        </div>

        <label class="form-label fw-semibold">Tiêu đề section</label>
        <input
          name="safety_notice_title"
          value="<%= pc?.safety_notice?.title || 'Lưu ý An toàn & Chống chỉ định (Quan trọng)' %>"
          class="form-control mb-3"
          placeholder="Lưu ý An toàn & Chống chỉ định (Quan trọng)"
        />

        <div id="safety_notice_wrapper" class="row row-cols-1 row-cols-md-2 g-3 admin-component-grid">
          <% const safetyBoxes = Array.isArray(pc?.safety_notice?.boxes) ? pc.safety_notice.boxes : []; %>
          <% safetyBoxes.forEach((box) => { %>
            <div class="instance position-relative admin-sub-card">
              <span type="button" class="remove-instance d-flex justify-content-center align-items-center rounded-circle admin-remove-size bg-danger position-absolute admin-top-n2 admin-right-2 fw-bold text-white">X</span>
              <label class="form-label fw-semibold">Box title</label>
              <input
                name="safety_title"
                value="<%= box?.title || '' %>"
                placeholder="TUYỆT ĐỐI KHÔNG SỬ DỤNG CHO"
                class="form-control mb-3"
              />
              <label class="form-label fw-semibold">Nội dung</label>
              <textarea
                name="safety_content"
                class="form-control mb-3 tinymce-editor"
                placeholder="Nhập nội dung..."
              ><%- box?.content || '' %></textarea>
            </div>
          <% }) %>
        </div>
      </div>
    </section>
    <!-- END -->
    <!-- FAQ -->
    <section class="card border-0 shadow-sm admin-config-section">
      <button
        type="button"
        onclick="toggleSection('faq')"
        class="admin-section-toggle btn btn-link w-100 d-flex justify-content-between align-items-center text-start text-decoration-none fw-semibold"
      >
        FAQ Section
        <span>+</span>
      </button>
      <!-- Content -->
      <div class="card-body" id="faq">
        <input value="<%=pc?.faq?.title||''%>" name="faq_title" type="text" class="form-control" placeholder="title...">
        <input value="<%=pc?.faq?.desc||''%>" name="faq_desc" type="text" class="form-control" placeholder="desc...">
        <div>
          <div class="d-flex justify-content-between align-items-center py-4">
            <h4 class="fw-bold">faq card</h4>
            <button id="cta_add_faq_card" type="button" class="btn btn-success fw-semibold">add faq component</button>
          </div>
          <div id="faq_wrapper" class="row row-cols-1 row-cols-md-2 g-4 admin-component-grid">
            <%if(pc?.faq?.list && pc?.faq?.list.length >0){%>
              <%pc.faq.list.forEach(i=>{%>
                <div class="instance position-relative admin-sub-card">
                  <span class="remove-instance admin-remove-size rounded-3 bg-danger text-white fw-bold d-flex align-items-center justify-content-center position-absolute admin-top-n2 admin-right-2">X</span>
                  <div>
                    <input value="<%=i.question%>" name="question" type="text" class="form-control" placeholder="question...">
                    <textarea name="anwser" id="" class="form-control" placeholder="anwser..."><%=i.anwser%></textarea>
                  </div>
                </div>
              <%})%>
            <%}%>
          </div>
        </div>
      </div>
    </section>
    <!-- END -->
    <!-- UX: Feedback carousel + So sánh + CES (landing) -->
    <section class="card border-0 shadow-sm admin-config-section">
      <button
        type="button"
        onclick="toggleSection('ux_blocks')"
        class="admin-section-toggle btn btn-link w-100 d-flex justify-content-between align-items-center text-start text-decoration-none fw-semibold"
      >
        UX — Phản hồi video / So sánh / Vì sao chọn CES
        <span>+</span>
      </button>
      <div class="p-4 space-y-6" id="ux_blocks">
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0 pt-4 px-4">
            <h3 class="fw-bold text-body mb-1">Quà tặng / CTA trước video phản hồi</h3>
            <p class="text-body-secondary small mb-0">
              Hiển thị hình quà tặng, mô tả, ưu đãi, countdown và nút đặt hàng qua Zalo.
            </p>
          </div>
          <div class="card-body p-4">
            <div class="row g-4">
              <div class="col-lg-5">
                <label class="form-label fw-semibold">Hình ảnh quà tặng</label>
                <div class="image_action admin-image-action mb-3">
                  <div class="d-flex justify-content-between align-items-center">
                    <button
                      type="button"
                      class="chooseImg btn btn-outline-success flex-grow-1"
                    >
                      Chọn ảnh
                    </button>
                    <input
                      type="text"
                      name="gift_promo_image_url"
                      value="<%= pc?.gift_promo?.image_url || '' %>"
                      class="img_input form-control d-none"
                      placeholder="img"
                    />
                  </div>
                  <div class="img_preview admin-image-preview border rounded-3">
                    <img
                      src="/<%= pc?.gift_promo?.image_url || '' %>"
                      alt=""
                      class="admin-image-preview-img"
                    />
                  </div>
                </div>

                <label class="form-label fw-semibold">Text mô tả dưới ảnh (TinyMCE)</label>
                <textarea
                  name="gift_promo_image_desc"
                  class="form-control tinymce-editor"
                  rows="4"
                  placeholder="Mô tả quà tặng, công dụng..."
                ><%- pc?.gift_promo?.image_desc || '' %></textarea>
              </div>

              <div class="col-lg-7">
                <div class="row g-3">
                  <div class="col-12">
                    <label class="form-label fw-semibold">Tiêu đề</label>
                    <input
                      name="gift_promo_title"
                      value="<%= pc?.gift_promo?.title || '' %>"
                      class="form-control"
                      placeholder="Hãy để ToppiLife mang lại cho bạn..."
                    />
                  </div>
                  <div class="col-12">
                    <label class="form-label fw-semibold">Mô tả ngắn</label>
                    <textarea
                      name="gift_promo_subtitle"
                      class="form-control"
                      rows="3"
                      placeholder="Điều tốt cho sức khỏe chính là nền tảng của thành công!"
                    ><%= pc?.gift_promo?.subtitle || '' %></textarea>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold">Nội dung box ưu đãi</label>
                    <textarea
                      name="gift_promo_offer_label"
                      class="form-control tinymce-editor"
                      rows="4"
                      placeholder="Ưu đãi đặc biệt trong tháng này"
                    ><%- pc?.gift_promo?.offer_label || '' %></textarea>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold">Text giảm giá</label>
                    <input
                      name="gift_promo_discount_text"
                      value="<%= pc?.gift_promo?.discount_text || '' %>"
                      class="form-control"
                      placeholder="GIẢM NGAY 10%"
                    />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold">Thời gian đếm ngược</label>
                    <input
                      type="datetime-local"
                      name="gift_promo_countdown_until"
                      value="<%= pc?.gift_promo?.countdown_until || '' %>"
                      class="form-control"
                    />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-semibold">CTA button</label>
                    <input
                      name="gift_promo_cta_text"
                      value="<%= pc?.gift_promo?.cta_text || 'ĐẶT HÀNG NHẬN QUÀ NGAY' %>"
                      class="form-control"
                      placeholder="ĐẶT HÀNG NHẬN QUÀ NGAY"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div>
          <h3 class="fw-bold text-body">Phản hồi khách hàng (carousel)</h3>
          <input
            name="feedback_title"
            value="<%= pc?.feedback?.title || 'Phản hồi của khách hàng' %>"
            class="border w-100 px-3 py-2 rounded mt-2"
            placeholder="Tiêu đề"
          />
          <input
            name="feedback_subtitle"
            value="<%= pc?.feedback?.subtitle || 'Nội dung trước và sau khi sử dụng sp' %>"
            class="border w-100 px-3 py-2 rounded mt-2"
            placeholder="Mô tả phụ"
          />
          <label class="block small mt-2 text-secondary"
            >Danh sách URL YouTube (mỗi dòng 1 video; carousel cuộn ngang khi nhiều video)</label>
          <textarea
            name="feedback_video_urls"
            class="border w-100 px-3 py-2 rounded font-monospace small admin-min-h-100"
            placeholder="https://www.youtube.com/watch?v=..."
          ><%=(Array.isArray(pc?.feedback?.video_urls) ? pc.feedback.video_urls : []).join('\n')%></textarea>
          
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0 pt-4 px-4">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
              <div>
                <h3 class="fw-bold text-body mb-1">So sánh hiệu quả</h3>
                <p class="text-body-secondary small mb-0">
                  Tùy chỉnh nội dung bảng "Vì sao CES khác biệt hoàn toàn với các giải pháp khác?".
                </p>
              </div>
              <button id="cta_add_comparison_row" type="button" class="btn btn-success fw-semibold">
                Thêm dòng bảng
              </button>
            </div>
          </div>
          <div class="card-body p-4">
            <% const defaultComparisonColumns = ['Thuốc Ngủ', 'Thiền/Yoga', 'Massage', 'Liệu Pháp CES']; %>
            <% const savedComparisonColumns = Array.isArray(pc?.comparison?.table_columns) ? pc.comparison.table_columns : []; %>
            <% const comparisonColumns = defaultComparisonColumns.map((fallback, idx) => savedComparisonColumns[idx] || fallback); %>
            <% const comparisonRows = Array.isArray(pc?.comparison?.table_rows) && pc.comparison.table_rows.length ? pc.comparison.table_rows : [
              { label: 'Tốc độ hiệu quả', cells: ['Nhanh', 'Chậm', 'Nhanh/Tạm thời', 'Nhanh'] },
              { label: 'Nỗ lực người dùng', cells: ['Không cần', 'Đòi hỏi sự kiên nhẫn/Tập luyện', 'Phải đi lại/Chi phí cao', 'Thư giãn hoàn toàn tại nhà'] },
              { label: 'Tác dụng phụ/Lệ thuộc', cells: ['⚠️ Cao - Lờn thuốc, mệt mỏi', 'Không', 'Không', '✅ Không phụ thuộc, 0 tác dụng phụ nguy hiểm'] },
              { label: 'Cơ chế tác động', cells: ['Ép buộc hóa học', 'Tâm trí', 'Ngoài da/Cơ bắp', 'Tận gốc hệ thần kinh & não học não'] },
            ]; %>
            <label class="form-label fw-semibold">Tiêu đề section</label>
            <input
              name="comparison_title"
              value="<%= pc?.comparison?.title || 'Vì sao CES khác biệt hoàn toàn với các giải pháp khác?' %>"
              class="form-control mb-3"
              placeholder="Vì sao CES khác biệt hoàn toàn với các giải pháp khác?"
            />

            <div class="row row-cols-1 row-cols-md-4 g-3 mb-4">
              <% comparisonColumns.forEach((col, idx) => { %>
                <div>
                  <label class="form-label fw-semibold">Cột <%= idx + 1 %></label>
                  <input
                    name="comparison_table_column"
                    value="<%= col || '' %>"
                    class="form-control"
                    placeholder="Tên cột"
                  />
                </div>
              <% }) %>
            </div>

            <div id="comparison_table_wrapper" class="d-flex flex-column gap-3">
              <% comparisonRows.forEach((row) => { %>
                <div class="instance position-relative admin-sub-card">
                  <span type="button" class="remove-instance d-flex justify-content-center align-items-center rounded-circle admin-remove-size bg-danger position-absolute admin-top-n2 admin-right-2 fw-bold text-white">X</span>
                  <label class="form-label fw-semibold">Tên dòng</label>
                  <input
                    name="comparison_row_label"
                    value="<%= row?.label || '' %>"
                    class="form-control mb-3"
                    placeholder="Tốc độ hiệu quả"
                  />
                  <div class="row row-cols-1 row-cols-md-4 g-3">
                    <% for (let cellIdx = 0; cellIdx < 4; cellIdx++) { %>
                      <div>
                        <label class="form-label small text-body-secondary">Nội dung cột <%= cellIdx + 1 %></label>
                        <textarea
                          name="comparison_cell"
                          class="form-control"
                          rows="3"
                          placeholder="Nội dung ô..."
                        ><%= row?.cells?.[cellIdx] || '' %></textarea>
                      </div>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white border-0 pt-4 px-4">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
              <div>
                <h3 class="fw-bold text-body mb-1">Bảo chứng từ y khoa</h3>
                <p class="text-body-secondary small mb-0">
                  Tiêu đề, ảnh chứng nhận và các box nội dung phía dưới.
                </p>
              </div>
              <button id="cta_add_medical_proof_box" type="button" class="btn btn-success fw-semibold">
                Thêm box nội dung
              </button>
            </div>
          </div>
          <div class="card-body p-4">
            <div class="row g-4">
              <div class="col-lg-5">
                <label class="form-label fw-semibold">Ảnh bảo chứng</label>
                <span class="text-body-secondary small mb-0">
                  size: 800:200px
                </span>
                <div class="image_action admin-image-action mb-3">
                  <div class="d-flex justify-content-between align-items-center">
                    <button type="button" class="chooseImg btn btn-outline-success flex-grow-1">
                      Chọn ảnh
                    </button>
                    <input
                      type="text"
                      name="medical_proof_img_url"
                      value="<%= pc?.medical_proof?.img_url || '' %>"
                      class="img_input form-control d-none"
                      placeholder="img"
                    />
                  </div>
                  <div class="img_preview admin-image-preview border rounded-3">
                    <img
                      src="/<%= pc?.medical_proof?.img_url || '' %>"
                      alt=""
                      class="admin-image-preview-img"
                    />
                  </div>
                </div>
              </div>
              <div class="col-lg-7">
                <label class="form-label fw-semibold">Tiêu đề</label>
                <input
                  name="medical_proof_title"
                  value="<%= pc?.medical_proof?.title || 'An tâm tuyệt đối: Bảo chứng từ khoa học y khoa' %>"
                  class="form-control mb-3"
                  placeholder="An tâm tuyệt đối: Bảo chứng từ khoa học y khoa"
                />

                <div id="medical_proof_wrapper" class="row row-cols-1 row-cols-md-3 g-3 admin-component-grid">
                  <% const medicalProofBoxes = Array.isArray(pc?.medical_proof?.boxes) && pc.medical_proof.boxes.length ? pc.medical_proof.boxes : []; %>
                  <% medicalProofBoxes.forEach((box) => { %>
                    <div class="instance position-relative admin-sub-card">
                      <span type="button" class="remove-instance d-flex justify-content-center align-items-center rounded-circle admin-remove-size bg-danger position-absolute admin-top-n2 admin-right-2 fw-bold text-white">X</span>
                      <label class="form-label fw-semibold">Box title</label>
                      <input
                        name="medical_proof_box_title"
                        value="<%= box?.title || '' %>"
                        class="form-control mb-3"
                        placeholder="Lịch sử chứng minh"
                      />
                      <label class="form-label fw-semibold">Nội dung</label>
                      <textarea
                        name="medical_proof_box_content"
                        class="form-control mb-3 tinymce-editor"
                        placeholder="Nhập nội dung..."
                      ><%- box?.content || '' %></textarea>
                    </div>
                  <% }) %>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div>
          <h3 class="fw-bold text-body">Vì sao chọn CES</h3>
          <input
            name="ces_why_title"
            value="<%= pc?.ces_why?.title || 'Vì sao nhiều người chọn sử dụng máy kích thích điện sọ não (CES)?' %>"
            class="border w-100 px-3 py-2 rounded mt-2"
          />
          <h5 class="fw-bold mt-3 text-body">Ảnh minh họa</h5>
          <div class="image_action admin-image-action mb-3">
            <div class="d-flex justify-content-between align-items-center mt-3">
              <button
                type="button"
                class="chooseImg btn btn-outline-success flex-grow-1"
              >
                Chọn ảnh
              </button>
              <input
                type="text"
                name="ces_why_img_url"
                value="<%= pc?.ces_why?.img_url || '' %>"
                class="img_input form-control d-none"
                placeholder="img"
              />
            </div>
            <div class="img_preview admin-image-preview border rounded-3 mt-2">
              <img
                src="/<%= pc?.ces_why?.img_url || '' %>"
                alt=""
                class="admin-image-preview-img"
              />
            </div>
          </div>
          <label class="block small mt-2 text-secondary"
            >Gạch đầu dòng — mỗi dòng một ý</label>
          <textarea
            name="ces_why_bullets"
            class="form-control small admin-min-h-140"
          ><%=(Array.isArray(pc?.ces_why?.bullets) ? pc.ces_why.bullets : []).join('\n')%></textarea>
        </div>
      </div>
    </section>
    <!-- CONTACT -->
    <section class="card border-0 shadow-sm admin-config-section">
      <button
        type="button"
        onclick="toggleSection('contact')"
        class="admin-section-toggle btn btn-link w-100 d-flex justify-content-between align-items-center text-start text-decoration-none fw-semibold"
      >
        Contact Section
        <span>+</span>
      </button>
      <!-- Content -->
      <div class="card-body" id="contact">
        <input
          name="contact_title"
          value="<%=pc?.contact?.title||''%>"
          placeholder="Contact Title"
          class="form-control mb-3"
        />

        <textarea
          name="contact_desc"
          placeholder="Contact Description"
          class="form-control mb-3"
        ><%=pc?.contact?.desc||''%></textarea>
      </div>
    </section>
    <!-- END -->
  </div>
</form>

