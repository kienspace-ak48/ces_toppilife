        <div class="flex justify-between items-center py-4">
          <h4 class="font-semibold pt-3">Cards</h4>
          <button id="cta_add_solution_card" type="button" class="px-3 py-2 font-bold bg-green-500 text-white rounded-lg ">Add Solution Component</button>
        </div>

