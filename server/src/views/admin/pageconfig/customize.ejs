<div class="card border-0 shadow-sm mb-4"><div class="card-body p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3"><div><div class="text-uppercase text-primary fw-semibold small mb-1">Admin Config</div><h2 class="fw-bold">
    Customize section/ Tùy chỉnh cấu hình web
    <i
      class="text-primary fa-regular fa-circle-question"
    ></i>
  </h2><p class="text-body-secondary mb-0">Quản lý thông tin website, SEO và ảnh chia sẻ.</p></div><button
    id="btn_cta_save_config"
    class="btn btn-primary fw-semibold"
  >
    Save config
  </button></div></div><!-- page info -->
<section id="pageinfo" class="card border-0 shadow-sm">
  <div class="card-body p-4">
  <div class="row row-cols-1 row-cols-md-2 g-4 admin-component-grid">
    <!-- Email -->
    <div>
      <label class="form-label fw-medium">Email</label>
      <input
        type="text"
        name="pageinfo_email"
        value="<%=data?.customize?.email||''%>"
        class="form-control"
        placeholder="admin@gmail.com"
      />
    </div>

    <!-- Phone -->
    <div>
      <label class="form-label fw-medium">Phone number</label>
      <input
        type="text"
        name="pageinfo_phone"
        value="<%=data?.customize?.phone||''%>"
        class="form-control"
        placeholder="19001900"
      />
    </div>

    <!-- Zalo -->
    <div>
      <label class="form-label fw-medium">Zalo</label>
      <input
        type="text"
        name="pageinfo_zalo"
        value="<%=data?.customize?.zalo||''%>"
        class="form-control"
        placeholder="19001900"
      />
    </div>

    <!-- Address -->
    <div>
      <label class="form-label fw-medium">Address</label>
      <input
        type="text"
        name="pageinfo_address"
        value="<%=data?.customize?.address||''%>"
        class="form-control"
        placeholder="123 Đường ABC, Quận XYZ, TP.HCM"
      />
    </div>

    <!-- Facebook -->
    <div>
      <label class="form-label fw-medium">Facebook</label>
      <input
        type="text"
        name="pageinfo_facebook"
        value="<%=data?.customize?.facebook||''%>"
        class="form-control"
        placeholder="https://facebook.com/yourpage"
      />
    </div>

    <!-- TikTok -->
    <div>
      <label class="form-label fw-medium">TikTok</label>
      <input
        type="text"
        name="pageinfo_tiktok"
        value="<%=data?.customize?.tiktok||''%>"
        class="form-control"
        placeholder="https://tiktok.com/@yourpage"
      />
    </div>

    <!-- YouTube -->
    <div>
      <label class="form-label fw-medium">YouTube</label>
      <input
        type="text"
        name="pageinfo_youtube"
        value="<%=data?.customize?.youtube||''%>"
        class="form-control"
        placeholder="https://youtube.com/@yourchannel"
      />
    </div>

    <!-- Footer title -->
    <div>
      <label class="form-label fw-medium">land of destiny </label>
      <input
        type="text"
        name="worktime"
        value="<%=data?.customize?.worktime||''%>"
        class="form-control"
        placeholder="Title..."
      />
    </div>
  </div>

  <hr class="my-4" />
  <h4 class="fw-bold pb-4 fs-5">SEO</h4>

  <!-- SEO Section -->
  <div class="row row-cols-1 row-cols-md-2 g-4 admin-component-grid">
    <div>
      <div class="py-2">
        <label class="fw-medium">Website name</label>
        <input
          type="text"
          id="webname"
          value="<%=data?.customize?.title||''%>"
          class="form-control"
        />
      </div>

      <div class="py-2">
        <label class="fw-medium">Desc</label>
        <input
          type="text"
          id="desc"
          value="<%=data?.customize?.desc||''%>"
          class="form-control"
        />
      </div>
      <div class="py-2">
        <label class="fw-medium">Canonical</label>
        <input
          type="text"
          id="canonical"
          value="<%=data?.customize?.canonical ||''%>"
          class="form-control"
        />
      </div>
    </div>
    <!-- right -->
    <div>
      <div class="py-2">
        <label class="fw-medium">Keyword</label>
        <input
          type="text"
          id="keywords"
          value="<%=data?.customize?.keywords||''%>"
          class="form-control"
        />
      </div>

      <div class="py-2">
        <label class="fw-medium">OpenGraph image</label>
        <!-- image handle action -->
        <div class="image_action admin-image-action mb-3">
          <!-- <label for="">Image banner</label> -->
          <div class="d-flex justify-content-between align-items-center">
            <button
              class="chooseImg btn btn-outline-success flex-grow-1"
            >
              Chọn ảnh
            </button>
            <input
              type="text"
              name="website_img"
              value="<%=data?.customize?.img||''%>"
              class="img_input form-control d-none"
              placeholder="img"
            />
          </div>
          <div class="img_preview admin-image-preview border rounded-3">
            <img
              src="/<%=data?.customize?.img||''%>"
              alt=""
              class="admin-image-preview-img"
            />
          </div>
        </div>
        <!--  -->
      </div>
    </div>
  </div>
</div>
</section>
<!-- =================MODAL===================== -->
<div class="modal fade" id="gallery_modal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content border-0 shadow">
      <div class="modal-header">
        <div>
          <h5 class="modal-title fw-bold">Chọn ảnh</h5>
          <div class="text-body-secondary small">Chọn một ảnh từ thư viện để gán vào trường hiện tại.</div>
        </div>
        <button type="button" class="btn-close" data-coreui-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="imgList" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-4"></div>
      </div>
    </div>
  </div>
</div>
<!-- =============SCRIPT=============== -->
<script>
  var ctaChooseImg = document.querySelectorAll(".chooseImg");
  const chooseImgModal = document.querySelector("#gallery_modal");
  let imgInputIsFocusing = null;
  // combo choose image
  function openChooseImgModal() {
    coreui.Modal.getOrCreateInstance(chooseImgModal).show();
  }
  function closeChooseImgModal() {
    coreui.Modal.getOrCreateInstance(chooseImgModal).hide();
  }
  ctaChooseImg.forEach((el) => {
    el.addEventListener("click", (ev) => {
      console.log(el);
      loadImage();
      let input = el.closest(".image_action");
      imgInputIsFocusing = input;
      console.log("input ", input);
      openChooseImgModal();
    });
  });
  function selectImage(src) {
    imgInputIsFocusing.querySelector(".img_input").value = src;
    imgInputIsFocusing.querySelector(".img_preview img").src = "/" + src;
    closeChooseImgModal();
  }
  //
  function loadImage() {
    imgList.innerHTML = "Loading...";
    $.ajax({
      url: "/admin/gallery/image-getall",
      method: "GET",
      success: (res) => {
        if (res.success) {
          imgList.innerHTML = "";
          res.data.forEach((item) => {
            const col = document.createElement("div");
            col.className = "col";

            const img = document.createElement("img");
            img.src = "/" + item.path;
            img.className = "admin-gallery-picker-img w-100 cursor-pointer rounded border";
            img.onclick = () => selectImage(item.path);

            col.appendChild(img);
            imgList.appendChild(col);
          });
        }
      },
      error: (xhr, status, err) =>
        console.log(xhr.responseJSON?.mess || "Server error"),
    });
  }
  // end combo
  //
  document
    .getElementById("btn_cta_save_config")
    .addEventListener("click", async () => {
      const data = {
        pageinfo_email: document.querySelector("[name='pageinfo_email']").value,
        pageinfo_phone: document.querySelector("[name='pageinfo_phone']").value,
        pageinfo_zalo: document.querySelector("[name='pageinfo_zalo']").value,
        pageinfo_address: document.querySelector("[name='pageinfo_address']")
          .value,
        pageinfo_facebook: document.querySelector("[name='pageinfo_facebook']")
          .value,
        pageinfo_tiktok: document.querySelector("[name='pageinfo_tiktok']")
          .value,
        pageinfo_youtube: document.querySelector("[name='pageinfo_youtube']")
          .value,
        worktime: document.querySelector("[name='worktime']").value,
        webname: document.getElementById("webname").value,
        canonical: document.getElementById("canonical").value,
        desc: document.getElementById("desc").value,
        keywords: document.getElementById("keywords").value,
        // gg_a: document.getElementById("gg_a").value,
        // gg_wt: document.getElementById("gg_wt").value,
        img: document.querySelector("[name='website_img']").value,
      };

      const res = await fetch("/admin/page-config/customize-section", {
        method: "PUT",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await res.json();
      if (result.success) {
        alert("update successfully");
      } else {
        alert("update failed");
      }
    });
</script>
