<div class="admin-page">
  <div class="card border-0 shadow-sm mb-4 overflow-hidden">
    <div class="card-body p-4 p-lg-5 admin-hero-card">
      <div class="d-flex flex-column flex-lg-row justify-content-between gap-4">
        <div>
          <div class="text-uppercase text-primary fw-semibold small mb-2">Dashboard</div>
          <h1 class="display-6 fw-bold mb-2">
            Welcome back, <span id="greeting" class="admin-gradient-text"></span>
          </h1>
          <div id="quote" class="text-body-secondary"></div>
        </div>
        <div class="d-flex align-items-center">
          <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
            ToppiLife Admin
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <h2 class="h4 fw-bold mb-2">Quản trị nội dung</h2>
      <p class="text-body-secondary mb-0">
        Sử dụng sidebar để cập nhật landing page, thư viện ảnh và các cấu hình hiển thị.
      </p>
    </div>
  </div>
</div>
<script>
   
    const userName = '<%=user.name%>'; // Lấy từ hệ thống login

    const quotes = [
        'Hôm nay là một cơ hội mới để bạn tỏa sáng!',
        'Làm điều bạn có thể, với những gì bạn có.',
        'Thành công bắt đầu từ một bước đi nhỏ.',
        'Đừng ngừng cố gắng — những điều tốt đẹp đang đến!',
        'Trên hành trình của bạn, luôn có ánh sáng phía trước.',
    ];

    const randomQuote = quotes[Math.floor(Math.random() * quotes.length)];

    document.getElementById('greeting').innerText = userName;
    document.getElementById('quote').innerText = randomQuote;
</script>
